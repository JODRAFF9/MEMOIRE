    <bib:Article rdf:about="#item_236">
        <z:itemType>journalArticle</z:itemType>
        <dcterms:isPartOf>
           <bib:Journal></bib:Journal>
        </dcterms:isPartOf>
        <bib:authors>
            <rdf:Seq>
                <rdf:li>
                    <foaf:Person>
                        <foaf:surname>Henry</foaf:surname>
                        <foaf:givenName>Chandar</foaf:givenName>
                    </foaf:Person>
                </rdf:li>
                <rdf:li>
                    <foaf:Person>
                        <foaf:surname>Moulton</foaf:surname>
                        <foaf:givenName>Jermaine</foaf:givenName>
                    </foaf:Person>
                </rdf:li>
                <rdf:li>
                    <foaf:Person>
                        <foaf:surname>Ricketts</foaf:surname>
                        <foaf:givenName>Jermaine</foaf:givenName>
                    </foaf:Person>
                </rdf:li>
            </rdf:Seq>
        </bib:authors>
        <link:link rdf:resource="#item_235"/>
        <dc:title>Motives for sending Remittances to Jamaica: An application of the BPM61 definition of Remittances</dc:title>
        <dcterms:abstract>This paper seeks to explore the motives of migrants in sending remittances to Jamaica. Remittances were estimated by using the definition proposed in the sixth edition of the Balance of Payments manual and were utilized throughout the paper. The literature reveals three motives for sending remittances: altruism, self-interest/investment and tempered altruism or enlightened selfinterest. A VAR model was used to examine the possible motives migrants might have when remitting to Jamaica. The results indicate a combination of altruistic and self-interest/investment motive for sending remittances.</dcterms:abstract>
        <z:language>en</z:language>
        <z:libraryCatalog>Zotero</z:libraryCatalog>
    </bib:Article>
