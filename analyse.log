. do "code/stata/01_visitation.do"

. /* ============================================================
>    01_visitation.do â€” Exploration des deux bases EHCVM
>    ============================================================ */
. 
. do "code/stata/config.do"

. /* ============================================================
>    config.do â€” Chemins, constantes et options globales
>    ============================================================ */
. 
. global BASE_2018 "Base/2018-2019/SEN_2018_EHCVM_v02_M_Stata"

. global BASE_2021 "Base/2021-2022/SEN_2021_EHCVM-2_v01_M_STATA14"

. global OUTPUT    "code/stata/output"

. global TEMP      "code/stata/temp"

. global LOGS      "code/stata/logs"

. 
. global SEED          123

. global K_SEUIL       0.3333

. global N_BOOT        1000

. /* s13aq14 / s13q19 : 1=Meme ville  2=Meme region  3=Ailleurs au pays  >=4=Etranger */
. global CODE_ETRANGER_MIN 4

. 
. set seed $SEED

. set more off

. 
. foreach d in "$OUTPUT" "$TEMP" "$LOGS" {
  2.     capture mkdir "`d'"
  3. }

. 
end of do-file

. do "code/stata/utils.do"

. /* ============================================================
>    utils.do â€” Programmes utilitaires
>    ============================================================ */
. 
. /* Visitation rapide d'un fichier */
. program define visiter
  1.     args fichier nom
  2.     use "`fichier'", clear
  3.     di _newline "===== `nom' ====="
  4.     di "Observations : " _N
  5.     describe
  6.     codebook, compact
  7. end

. 
. /* Taux de deprivation */
. program define taux_dep
  1.     args var nom
  2.     quietly summarize `var'
  3.     di "  `nom' : " %5.1f r(mean)*100 "%"
  4. end

. 
. /* Prevalence par statut de traitement */
. program define prev_D
  1.     args outcome
  2.     tabstat `outcome', by(D) stat(mean n) format(%6.3f)
  3. end

. 
end of do-file

. 
