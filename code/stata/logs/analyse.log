>                 Enfant sans emploi ne poursuivant pas d'Ă©tudes et ne
>                 suivant pas de formation (NEET)
> */
. 
. /* ============================================================
>    Sous-programme : indicateurs menage (niveau logement)
>    Entree : base individus deja chargee (merge m:1 sur grappe menage)
>    ============================================================ */
. 
. capture program drop indic_menage

. program define indic_menage
  1.     /*
>        Fusionne ehcvm_menage et s11_me pour construire :
>          m_toilet, m_eau_source, m_ordures,
>          m_partag_toi, m_eau_temps, m_surpeup, m_combust
>        Requiert : grappe menage hhsize deja presents
>     */
.     args annee
  2. 
.     if `annee' == 2018 {
  3.         local base "$BASE_2018"
  4.         local v_partag "s11q56"
  5.         local v_tps_ss "s11q29a"
  6.         local v_tps_sp "s11q31a"
  7.         local v_comb   "s11q53"
  8.     }
  9.     else {
 10.         local base "$BASE_2021"
 11.         local v_partag "s11q55"
 12.         local v_tps_ss "s11q28a"
 13.         local v_tps_sp "s11q30a"
 14.         local v_comb   "s11q52"
 15.     }
 16.     /* Annexe I : combustible solide = bois ramasse(1), bois achete(2),
>        charbon de bois(3), dechets animaux(7), autres(8). Exclut gaz(4),
>        electricite(5), petrole/huile(6) consideres comme non solides. */
.     local comb_vars "`v_comb'__1 `v_comb'__2 `v_comb'__3 `v_comb'__7 `v_comb'__8"
 17. 
.     /* Binaires harmonises depuis ehcvm_menage
>        NB : ehcvm_menage n'a pas grappe/menage, seulement hhid
>             2018 : hhid = grappe * 1000 + menage  (range 1001-598012)
>             2021 : hhid = grappe * 100  + menage  (range 201-59812)  */
.     capture drop hhid
 18.     if `annee' == 2018 gen long hhid = grappe * 1000 + menage
 19.     else               gen long hhid = grappe * 100  + menage
 20.     merge m:1 hhid using ///
>         "`base'/ehcvm_menage_sen`annee'.dta", ///
>         keepusing(toilet eauboi_ss eauboi_sp ordure) ///
>         nogenerate keep(master match)
 21. 
.     /* [Dim 1/7 : Assainissement] Indicateur 1 â€” Type de sanitaire
>        (toilet, harmonise depuis s11q55 en 2018 / s11q54 en 2021) */
.     gen byte m_toilet    = (toilet == 0)          if !missing(toilet)
 22. 
.     /* [Dim 2/7 : Eau] Indicateur 1 â€” Source d'eau de boisson
>        (eauboi_ss/eauboi_sp, harmonise depuis s11q27a et s11q27b) */
.     gen byte m_eau_source = (eauboi_ss == 0 | eauboi_sp == 0) ///
>         if !missing(eauboi_ss) | !missing(eauboi_sp)
 23. 
.     /* [Dim 3/7 : Logement] Indicateur 1 â€” Debarras des ordures menageres
>        (ordure, harmonise depuis s11q54) */
.     gen byte m_ordures   = (ordure == 0)           if !missing(ordure)
 24. 
.     /* Variables brutes depuis s11_me */
.     preserve
 25.         use "`base'/s11_me_sen`annee'.dta", clear
 26.         keep grappe menage s11q02 `v_partag' `v_tps_ss' `v_tps_sp' `comb_vars'
 27.         tempfile s11_temp
 28.         save `s11_temp'
 29.     restore
 30.     merge m:1 grappe menage using `s11_temp', nogenerate keep(master match)
 31. 
.     /* [Dim 1/7 : Assainissement] Indicateur 2 â€” Partage des toilettes
>        (2018: s11q56 ; 2021: s11q55) */
.     gen byte m_partag_toi = (`v_partag' == 1)       if !missing(`v_partag')
 32.     replace  m_partag_toi = 0                        if missing(m_partag_toi)
 33. 
.     /* [Dim 2/7 : Eau] Indicateur 2 â€” Temps d'acces a l'eau
>        Prive si > 30 min en saison seche OU en saison des pluies
>        (2018: s11q29a / s11q31a ; 2021: s11q28a / s11q30a) */
.     gen byte m_eau_temps  = (`v_tps_ss' > 30 & !missing(`v_tps_ss')) | ///
>                              (`v_tps_sp' > 30 & !missing(`v_tps_sp'))
 34.     replace  m_eau_temps  = 0 if missing(`v_tps_ss') & missing(`v_tps_sp')
 35.     rename s11q02 nb_pieces
 36. 
.     /* [Dim 3/7 : Logement] Indicateur 2 â€” Surpeuplement
>        Prive si hhsize/nb_pieces (s11q02) > 3 (calcule apres merge welfare) */
.     gen byte m_surpeup = (hhsize / nb_pieces > 3) ///
>         if !missing(nb_pieces) & nb_pieces > 0 & !missing(hhsize)
 37.     replace  m_surpeup = 0 if missing(m_surpeup)
 38. 
.     /* [Dim 5/7 : Sante] Indicateur 1 â€” Combustible solide pour cuisiner
>        (2018: s11q53 ; 2021: s11q52, modalites bois ramasse/achete/
>        charbon/dechets animaux/autres â€” cf. comb_vars) */
.     gen byte m_combust = 0
 39.     foreach v of varlist `comb_vars' {
 40.         replace m_combust = 1 if `v' >= 1 & !missing(`v')
 41.     }
 42. 
.     /* [Dim 5/7 : Sante] Indicateur 2 â€” Acces a une structure de sante
>        (module communautaire s02_co). Enfant prive si, dans sa localite
>        (grappe), aucun des 3 services de sante (Hopital public/prive=5,
>        Autre centre de sante public=6, Cabinet medical/Clinique privee=7)
>        n'est accessible a pied (s02q02 == 1 "Pieds" comme principal moyen
>        de locomotion).
>        2018 : long format avec identifiant de service s02q00.
>        2021 : long format sans identifiant explicite, mais 26 lignes/grappe
>               dans le meme ordre que la liste de services 2018 ;
>               service_id = rang (_n) au sein de la grappe. */
.     preserve
 43.         use "`base'/s02_co_sen`annee'.dta", clear
 44.         if `annee' == 2018 {
 45.             keep if inlist(s02q00, 5, 6, 7)
 46.         }
 47.         else {
 48.             bysort grappe: gen byte service_id = _n
 49.             keep if inlist(service_id, 5, 6, 7)
 50.         }
 51.         gen byte acces_pied = (s02q02 == 1) if !missing(s02q02)
 52.         replace  acces_pied = 0 if missing(acces_pied)
 53.         collapse (max) acces_pied, by(grappe)
 54.         tempfile s02_temp
 55.         save `s02_temp'
 56.     restore
 57.     merge m:1 grappe using `s02_temp', nogenerate keep(master match)
 58.     gen byte m_acces_sante = (acces_pied == 0) if !missing(acces_pied)
 59.     replace  m_acces_sante = 0 if missing(m_acces_sante)
 60.     capture drop acces_pied
 61. 
.     /* [Dim 4/7 : Nutrition] Indicateur 1 â€” Securite alimentaire (FIES)
>        (s08a â€” 2018 et 2021)
>        Definition N-MODA : membre ayant saute un repas, mange moins que necessaire,
>        manque de nourriture, eu faim ou passe une journee sans manger
>        s08aq04 : saute repas | s08aq05 : mange moins | s08aq06 : plus de nourriture
>        s08aq07 : faim        | s08aq08 : journee sans manger
>        1=Oui 2=Non 98/99=NSP/Refus (traites comme Non)  */
.     preserve
 62.         use "`base'/s08a_me_sen`annee'.dta", clear
 63.         gen byte m_securite = 0
 64.         foreach v in s08aq04 s08aq05 s08aq06 s08aq07 s08aq08 {
 65.             replace m_securite = 1 if `v' == 1 & !missing(`v')
 66.         }
 67.         keep grappe menage m_securite
 68.         tempfile s08a_temp
 69.         save `s08a_temp'
 70.     restore
 71.     merge m:1 grappe menage using `s08a_temp', ///
>         keepusing(m_securite) nogenerate keep(master match)
 72.     replace m_securite = 0 if missing(m_securite)
 73. 
.     /* [Dim 4/7 : Nutrition] Indicateur 2 â€” Diversite alimentaire
>        (s08b1 â€” 2018 seulement)
>        Definition N-MODA : 4 macro-groupes (carbohydrates, proteines,
>        fruits/legumes, graisses) consommes chaque jour sur la semaine (7/7)
>        Mapping s08b02a-j :
>          Carbohydrates : max(a cereales, b tubercules)
>          Proteines     : max(c legumineuses, e poisson/viande, g lait/oeufs)
>          Fruits/legumes: max(d legumes, f fruits)
>          Graisses      : h huile/graisse
>        Prive si au moins un groupe < 7 jours (5-17 ans)  */
.     gen byte m_diversite = 0
 74.     if `annee' == 2018 {
 75.         preserve
 76.             use "`base'/s08b1_me_sen2018.dta", clear
 77.             foreach v of varlist s08b02a-s08b02j {
 78.                 replace `v' = 0 if missing(`v')
 79.             }
 80.             gen g_carb  = max(s08b02a, s08b02b)
 81.             gen g_prot  = max(s08b02c, s08b02e, s08b02g)
 82.             gen g_fv    = max(s08b02d, s08b02f)
 83.             gen g_gras  = s08b02h
 84.             gen byte m_diversite = ///
>                 (g_carb < 7 | g_prot < 7 | g_fv < 7 | g_gras < 7)
 85.             keep grappe menage m_diversite
 86.             tempfile s08b_temp
 87.             save `s08b_temp'
 88.         restore
 89.         merge m:1 grappe menage using `s08b_temp', ///
>             keepusing(m_diversite) nogenerate keep(master match)
 90.         replace m_diversite = 0 if missing(m_diversite)
 91.     }
 92. end

. 
. /* ============================================================
>    Sous-programme : acte de naissance (s01_me)
> 
>    [Dim 6/7 : Protection de l'enfant] Indicateur 1 â€” Disponibilite
>    de l'acte de naissance (s01q05, identique 2018/2021)
>    ============================================================ */
. 
. capture program drop indic_acte_nais

. program define indic_acte_nais
  1.     args annee
  2. 
.     if `annee' == 2018 local base "$BASE_2018"
  3.     else               local base "$BASE_2021"
  4. 
.     preserve
  5.         use "`base'/s01_me_sen`annee'.dta", clear
  6.         if `annee' == 2018 rename s01q00a numind
  7.         else               rename membres__id numind
  8.         keep grappe menage numind s01q05
  9.         gen byte m_acte_nais = (s01q05 == 2) if !missing(s01q05)
 10.         tempfile s01_temp
 11.         save `s01_temp'
 12.     restore
 13. 
.     merge m:1 grappe menage numind using `s01_temp', ///
>         keepusing(m_acte_nais) nogenerate keep(master match)
 14.     replace m_acte_nais = 0 if missing(m_acte_nais)
 15. end

. 
. /* ============================================================
>    Sous-programme : agregation N-MODA et Alkire-Foster
>    ============================================================ */
. 
. capture program drop agreger_ipm

. program define agreger_ipm
  1.     args annee
  2. 
.     /* Groupes d'age MODA */
.     gen byte groupe_moda = .
  3.     replace  groupe_moda = 1 if age <= 4
  4.     replace  groupe_moda = 2 if age >= 5  & age <= 14
  5.     replace  groupe_moda = 3 if age >= 15 & age <= 17
  6.     label define grp 1 "0-4 ans" 2 "5-14 ans" 3 "15-17 ans", replace
  7.     label values groupe_moda grp
  8. 
.     /* â”€â”€ Dimensions N-MODA (union intra-dimension des indicateurs) â”€â”€
>        Chaque dim_* combine les indicateurs construits ci-dessus, avec
>        application des groupes d'age propres a l'Annexe I. */
. 
.     /* [Dim 1/7 : Assainissement] = indic.1 (type sanitaire) OU indic.2 (partage) */
.     gen byte dim_assai  = (m_toilet == 1 | m_partag_toi == 1)
  9. 
.     /* [Dim 2/7 : Eau] = indic.1 (source) OU indic.2 (temps d'acces) */
.     gen byte dim_eau    = (m_eau_source == 1 | m_eau_temps == 1)
 10. 
.     /* [Dim 3/7 : Logement] = indic.1 (ordures) OU indic.2 (surpeuplement) */
.     gen byte dim_logem  = (m_ordures == 1 | m_surpeup == 1)
 11. 
.     /* [Dim 4/7 : Nutrition] = indic.1 securite alim (0-17 ans)
>        OU indic.2 diversite alimentaire (5-17 ans seulement) */
.     gen byte dim_nutri = 0
 12.     replace  dim_nutri = 1 if m_securite == 1
 13.     replace  dim_nutri = 1 if m_diversite == 1 & age >= 5
 14. 
.     /* [Dim 5/7 : Sante] = indic.1 (combustible) OU indic.2 (acces structure) */
.     gen byte dim_sante  = (m_combust == 1 | m_acces_sante == 1)
 15. 
.     /* [Dim 7/7 : Education] selon groupe d'age :
>        5-14 ans  -> indic.2 (scolarisation)
>        15-17 ans -> indic.1 (lecture-ecriture) OU indic.3 (NEET) */
.     gen byte dim_educ   = 0
 16.     replace  dim_educ   = m_scol  if groupe_moda == 2
 17.     replace  dim_educ   = (m_alfab == 1 | m_neet == 1) if groupe_moda == 3
 18. 
.     /* [Dim 6/7 : Protection de l'enfant] selon groupe d'age :
>        0-4 ans   -> indic.1 (acte naissance) OU indic.3 (separation parentale)
>        5-14 ans  -> indic.1 OU indic.2 (travail enfants) OU indic.3
>        15-17 ans -> indic.3 seulement (acte naissance non pertinent > 14 ans) */
.     gen byte dim_protect = 0
 19.     replace  dim_protect = (m_acte_nais == 1 | m_parents == 1) ///
>         if groupe_moda == 1
 20.     replace  dim_protect = (m_acte_nais == 1 | m_trav_enf == 1 | m_parents == 1) ///
>         if groupe_moda == 2
 21.     replace  dim_protect = (m_parents == 1) if groupe_moda == 3
 22. 
.     gen byte nb_dep    = dim_assai + dim_eau + dim_logem + dim_nutri + ///
>                          dim_sante + dim_protect + dim_educ
 23.     gen byte pauvre_MODA = (nb_dep >= $K_MODA) if !missing(nb_dep)
 24. 
.     /* Intensite moyenne N-MODA (Annexe II : A = part des 7 dimensions
>        en privation, calculee sur les enfants pauvres pauvre_MODA==1) */
.     gen float intensite_moda = nb_dep / 7
 25. 
.     /* â”€â”€ Indicateurs Alkire-Foster â”€â”€ */
. 
.     gen byte d1_educ  = 0
 26.     replace  d1_educ  = 1 if age >= 6 & (scol == 0 | missing(scol))
 27.     gen byte d2_sante = 0
 28.     replace  d2_sante = 1 if mal30j == 1 & con30j == 0 ///
>         & !missing(mal30j) & !missing(con30j)
 29.     gen byte d3_nutri = 0
 30.     replace  d3_nutri = 1 if age <= 4 & mal30j == 1 & !missing(mal30j)
 31.     gen byte d4_eau   = m_eau_source
 32.     gen byte d5_assai = m_toilet
 33.     gen byte d6_habit = dim_logem
 34. 
.     gen score_dep = (d1_educ + d2_sante + d3_nutri + ///
>                      d4_eau  + d5_assai + d6_habit) / 6
 35.     gen byte pauvre_AF = (score_dep >= $K_SEUIL) if !missing(score_dep)
 36. 
.     /* â”€â”€ Affichage â”€â”€ */
. 
.     di _newline "=== N-MODA `annee' (k=$K_MODA, 7 dimensions) ==="
 37.     quietly summarize pauvre_MODA
 38.     di "  H = " %6.3f r(mean)*100 "%"
 39.     di "  Privation par dimension :"
 40.     foreach dim in assai eau logem nutri sante protect educ {
 41.         taux_dep dim_`dim' "`dim'"
 42.     }
 43.     tabstat pauvre_MODA nb_dep, by(groupe_moda) stat(mean n) format(%6.3f)
 44. 
.     di _newline "=== Alkire-Foster `annee' (k=$K_SEUIL, 6 indicateurs) ==="
 45.     quietly summarize pauvre_AF
 46.     scalar H_af = r(mean)
 47.     quietly summarize score_dep if pauvre_AF == 1
 48.     scalar A_af = r(mean)
 49.     di "  H=" %6.3f H_af "  A=" %6.3f A_af "  M0=" %6.3f H_af * A_af
 50. end

. 
. /* ============================================================
>    Boucle principale sur les deux annees
>    ============================================================ */
. 
. foreach annee in 2018 2021 {
  2. 
.     if `annee' == 2018 local base "$BASE_2018"
  3.     else               local base "$BASE_2021"
  4. 
.     /* 1. Individus 0-17 ans */
.     use "`base'/ehcvm_individu_sen`annee'.dta", clear
  5.     keep if age >= 0 & age <= 17 & !missing(age)
  6.     gen annee = `annee'
  7.     di _newline ">>> Enfants `annee' : " _N
  8. 
.     /* 2. Welfare (hhsize, pcexp, covariables PSM) */
.     merge m:1 grappe menage using ///
>         "`base'/ehcvm_welfare_sen`annee'.dta", ///
>         keepusing(hhsize pcexp region milieu hgender hage heduc hmstat hhweight) ///
>         nogenerate keep(master match)
  9. 
.     /* 3. Indicateurs menage */
.     indic_menage `annee'
 10. 
.     /* 4. Acte de naissance */
.     indic_acte_nais `annee'
 11. 
.     /* 5. Indicateurs individuels (ehcvm_individu : scol, activ7j, lien,
>           alfab/alfa) â€” un bloc par dimension de l'Annexe I */
. 
.     /* [Dim 7/7 : Education] Indicateur 2 â€” Frequentation scolaire
>        Non-scolarise, groupe d'age 5-14 ans (variable scol) */
.     gen byte m_scol = 0
 12.     replace  m_scol = 1 if age >= 5 & age <= 14 & (scol == 0 | missing(scol))
 13. 
.     /* [Dim 6/7 : Protection de l'enfant] Indicateur 2 â€” Travail des enfants
>        Groupe d'age 5-14 ans, composante economique uniquement
>        (activ7j : Occupe=1, Chomeur=2). L'EHCVM ne comporte pas de module
>        time-use permettant de mesurer le travail domestique (corvees) ;
>        cette composante de l'Annexe I n'est donc pas operationnalisable
>        avec les donnees disponibles. */
.     gen byte m_trav_enf = 0
 14.     replace  m_trav_enf = 1 if age >= 5 & age <= 14 & ///
>         (activ7j == 1 | activ7j == 2) & !missing(activ7j)
 15. 
.     /* [Dim 6/7 : Protection de l'enfant] Indicateur 3 â€” Separation parentale
>        Prive si l'enfant ne vit pas avec ses deux parents biologiques
>        (lien > 3, tous groupes d'age) */
.     gen byte m_parents = (lien > 3) if !missing(lien)
 16.     replace  m_parents = 0 if missing(m_parents)
 17. 
.     /* [Dim 7/7 : Education] Indicateur 1 â€” Capacite de lecture et d'ecriture
>        Groupe d'age 15-17 ans (2018: alfab ; 2021: alfa) */
.     gen byte m_alfab = 0
 18.     if `annee' == 2018 {
 19.         replace m_alfab = 1 if age >= 15 & alfab == 0 & !missing(alfab)
 20.     }
 21.     else {
 22.         capture confirm variable alfa
 23.         if !_rc replace m_alfab = 1 if age >= 15 & alfa == 0 & !missing(alfa)
 24.     }
 25. 
.     /* [Dim 7/7 : Education] Indicateur 3 â€” NEET
>        Groupe d'age 15-17 ans : ni scolarise ni employe
>        (activ7j != 1 : inactifs + chomeurs) */
.     gen byte m_neet = 0
 26.     replace  m_neet = 1 if age >= 15 & ///
>         (scol == 0 | missing(scol)) & (activ7j != 1 | missing(activ7j))
 27. 
.     /* Acte de naissance non pertinent > 14 ans */
.     replace m_acte_nais = 0 if age > 14
 28. 
.     /* 6. Agregation IPM */
.     agreger_ipm `annee'
 29. 
.     /* 7. Sauvegarde */
.     save "$TEMP/enfants_dep_`annee'.dta", replace
 30.     di _newline ">>> Sauvegarde : enfants_dep_`annee'.dta (" _N " obs)"
 31. }
