. local i = 0

. foreach dim of local dims {
  2.     local ++i
  3.     quietly svy: reg dim_`dim' i.t##i.D
  4.     quietly lincom 1.t#1.D
  5.     matrix ATT[`i',1] = r(estimate)
  6.     matrix LB[`i',1]  = r(estimate) - 1.96*r(se)
  7.     matrix UB[`i',1]  = r(estimate) + 1.96*r(se)
  8.     di "  dim_`dim' : ATT=" %8.4f r(estimate) "  SE=" %7.4f r(se) "  p=" %6.4f r(p)
  9. }
