. do "code/stata/03_deprivation.do"

. /* ============================================================
>    03_deprivation.do â Indicateurs de pauvrete multidimensionnelle
> 
>    Approche 1 : Alkire-Foster (6 indicateurs, poids egaux, k=1/3)
>    Approche 2 : N-MODA Senegal (7 dimensions, k=4)
> 
>    Produit : $TEMP/enfants_dep_ANNEE.dta pour annee in {2018, 2021}
>    ============================================================ */
. 
. do "code/stata/config.do"

. /* ============================================================
>    config.do â Chemins, constantes et options globales
>    ============================================================ */
. 
. global BASE_2018 "Base/2018-2019/SEN_2018_EHCVM_v02_M_Stata"

. global BASE_2021 "Base/2021-2022/SEN_2021_EHCVM-2_v01_M_STATA14"

. global OUTPUT    "code/stata/output"

. global TEMP      "code/stata/temp"

. global LOGS      "code/stata/logs"

. 
. /* Parametres methodologiques */
. global SEED              123

. global K_SEUIL           0.3333   /* seuil Alkire-Foster (2 indicateurs sur 6) */

. global K_MODA            4        /* seuil N-MODA : >= 4 dimensions sur 7      */

. global N_BOOT            1000

. global CODE_ETRANGER_MIN 4        /* s13aq14 / s13q19 >= 4 = expediteur etranger */

. global CALIPER           0.05

. global K_VOISINS         4

. 
. set seed   $SEED

. set more   off

. set varabbrev off

. 
. foreach d in "$OUTPUT" "$TEMP" "$LOGS" {
  2.     capture mkdir "`d'"
  3. }

. 
end of do-file

. do "code/stata/utils.do"

. /* ============================================================
>    utils.do â Programmes utilitaires reutilisables
> 
>    Chaque programme est precede de "capture program drop" pour
>    eviter l'erreur r(110) "already defined" quand utils.do est
>    appele plusieurs fois dans la meme session Stata.
>    ============================================================ */
. 
. /* ââ Exploration rapide d'un fichier âââââââââââââââââââââââââ */
. capture program drop visiter

. program define visiter
  1.     args fichier nom
  2.     use "`fichier'", clear
  3.     di _newline "===== `nom' ====="
  4.     di "Observations : " _N
  5.     describe
  6.     codebook, compact
  7. end

. 
. /* ââ Taux de privation (%) ââââââââââââââââââââââââââââââââââââ */
. capture program drop taux_dep

. program define taux_dep
  1.     args var nom
  2.     quietly summarize `var'
  3.     di "  `nom' : " %5.1f r(mean)*100 "%"
  4. end

. 
. /* ââ Prevalence par statut de traitement ââââââââââââââââââââââ */
. capture program drop prev_D

. program define prev_D
  1.     args outcome
  2.     tabstat `outcome', by(D) stat(mean n) format(%6.3f)
  3. end

. 
. /* ââ ATT PSM-DD avec IC bootstrap ââââââââââââââââââââââââââââ */
. /*
>    Syntaxe : att_psmdd outcome poids nboot
>    Affiche ATT, SE bootstrap, IC 95%, p-valeur
> */
. capture program drop att_psmdd

. program define att_psmdd
  1.     args outcome poids nboot
  2. 
.     bootstrap att = _b[1.t#1.D], ///
>         reps(`nboot') seed($SEED) nodots: ///
>         reg `outcome' i.t##i.D [aw = `poids']
  3. 
.     estat bootstrap, percentile all
  4. end

. 
. /* ââ Verification equilibre SMD ââââââââââââââââââââââââââââââ */
. /*
>    Affiche les SMD avant/apres appariement pour une liste de vars
> */
. capture program drop check_balance

. program define check_balance
  1.     args varlist_str
  2.     di _newline "=== Balance des covariables (SMD) ==="
  3.     pstest `varlist_str', both
  4. end

. 
end of do-file

. 
. /* ============================================================
>    Sous-programme : indicateurs menage (niveau logement)
>    Entree : base individus deja chargee (merge m:1 sur grappe menage)
>    ============================================================ */
. 
. capture program drop indic_menage

. program define indic_menage
  1.     /*
>        Fusionne ehcvm_menage et s11_me pour construire :
>          m_toilet, m_eau_source, m_ordures,
>          m_partag_toi, m_eau_temps, m_surpeup, m_combust
>        Requiert : grappe menage hhsize deja presents
>     */
.     args annee
  2. 
.     if `annee' == 2018 {
  3.         local base "$BASE_2018"
  4.         local v_partag "s11q56"
  5.         local v_tps_ss "s11q29a"
  6.         local v_comb   "s11q53"
  7.     }
  8.     else {
  9.         local base "$BASE_2021"
 10.         local v_partag "s11q55"
 11.         local v_tps_ss "s11q28a"
 12.         local v_comb   "s11q52"
 13.     }
 14.     local comb_vars "`v_comb'__1 `v_comb'__2 `v_comb'__3 `v_comb'__7"
 15. 
.     /* Binaires harmonises depuis ehcvm_menage
>        NB : ehcvm_menage n'a pas grappe/menage, seulement hhid
>             2018 : hhid = grappe * 1000 + menage  (range 1001-598012)
>             2021 : hhid = grappe * 100  + menage  (range 201-59812)  */
.     capture drop hhid
 16.     if `annee' == 2018 gen long hhid = grappe * 1000 + menage
 17.     else               gen long hhid = grappe * 100  + menage
 18.     merge m:1 hhid using ///
>         "`base'/ehcvm_menage_sen`annee'.dta", ///
>         keepusing(toilet eauboi_ss eauboi_sp ordure) ///
>         nogenerate keep(master match)
 19. 
.     gen byte m_toilet    = (toilet == 0)          if !missing(toilet)
 20.     gen byte m_eau_source = (eauboi_ss == 0 | eauboi_sp == 0) ///
>         if !missing(eauboi_ss) | !missing(eauboi_sp)
 21.     gen byte m_ordures   = (ordure == 0)           if !missing(ordure)
 22. 
.     /* Variables brutes depuis s11_me */
.     preserve
 23.         use "`base'/s11_me_sen`annee'.dta", clear
 24.         keep grappe menage s11q02 `v_partag' `v_tps_ss' `comb_vars'
 25.         tempfile s11_temp
 26.         save `s11_temp'
 27.     restore
 28.     merge m:1 grappe menage using `s11_temp', nogenerate keep(master match)
 29. 
.     gen byte m_partag_toi = (`v_partag' == 1)       if !missing(`v_partag')
 30.     replace  m_partag_toi = 0                        if missing(m_partag_toi)
 31.     gen byte m_eau_temps  = (`v_tps_ss' > 30 & !missing(`v_tps_ss'))
 32.     replace  m_eau_temps  = 0                        if missing(`v_tps_ss')
 33.     rename s11q02 nb_pieces
 34. 
.     /* Surpeuplement : calcule apres merge welfare (hhsize deja present) */
.     gen byte m_surpeup = (hhsize / nb_pieces > 3) ///
>         if !missing(nb_pieces) & nb_pieces > 0 & !missing(hhsize)
 35.     replace  m_surpeup = 0 if missing(m_surpeup)
 36. 
.     /* Combustible solide */
.     gen byte m_combust = 0
 37.     foreach v of varlist `comb_vars' {
 38.         replace m_combust = 1 if `v' >= 1 & !missing(`v')
 39.     }
 40. end

. 
. /* ============================================================
>    Sous-programme : acte de naissance (s01_me)
>    ============================================================ */
. 
. capture program drop indic_acte_nais

. program define indic_acte_nais
  1.     args annee
  2. 
.     if `annee' == 2018 local base "$BASE_2018"
  3.     else               local base "$BASE_2021"
  4. 
.     preserve
  5.         use "`base'/s01_me_sen`annee'.dta", clear
  6.         if `annee' == 2018 rename s01q00a numind
  7.         else               rename membres__id numind
  8.         keep grappe menage numind s01q05
  9.         gen byte m_acte_nais = (s01q05 == 2) if !missing(s01q05)
 10.         tempfile s01_temp
 11.         save `s01_temp'
 12.     restore
 13. 
.     merge m:1 grappe menage numind using `s01_temp', ///
>         keepusing(m_acte_nais) nogenerate keep(master match)
 14.     replace m_acte_nais = 0 if missing(m_acte_nais)
 15. end

. 
. /* ============================================================
>    Sous-programme : agregation N-MODA et Alkire-Foster
>    ============================================================ */
. 
. capture program drop agreger_ipm

. program define agreger_ipm
  1.     args annee
  2. 
.     /* Groupes d'age MODA */
.     gen byte groupe_moda = .
  3.     replace  groupe_moda = 1 if age <= 4
  4.     replace  groupe_moda = 2 if age >= 5  & age <= 14
  5.     replace  groupe_moda = 3 if age >= 15 & age <= 17
  6.     label define grp 1 "0-4 ans" 2 "5-14 ans" 3 "15-17 ans", replace
  7.     label values groupe_moda grp
  8. 
.     /* ââ Dimensions N-MODA (union intra-dimension) ââ */
. 
.     gen byte dim_assai  = (m_toilet == 1 | m_partag_toi == 1)
  9.     gen byte dim_eau    = (m_eau_source == 1 | m_eau_temps == 1)
 10.     gen byte dim_logem  = (m_ordures == 1 | m_surpeup == 1)
 11.     gen byte dim_nutri  = 0   /* s14/s20 non harmonises â placeholder */
 12.     gen byte dim_sante  = (m_combust == 1)
 13.     gen byte dim_educ   = 0
 14.     replace  dim_educ   = m_scol  if groupe_moda == 2
 15.     replace  dim_educ   = (m_alfab == 1 | m_neet == 1) if groupe_moda == 3
 16.     gen byte dim_protect = 0
 17.     replace  dim_protect = (m_acte_nais == 1 | m_parents == 1) ///
>         if groupe_moda == 1
 18.     replace  dim_protect = (m_acte_nais == 1 | m_trav_enf == 1 | m_parents == 1) ///
>         if groupe_moda == 2
 19.     replace  dim_protect = (m_parents == 1) if groupe_moda == 3
 20. 
.     gen byte nb_dep    = dim_assai + dim_eau + dim_logem + dim_nutri + ///
>                          dim_sante + dim_protect + dim_educ
 21.     gen byte pauvre_MODA = (nb_dep >= $K_MODA) if !missing(nb_dep)
 22. 
.     /* ââ Indicateurs Alkire-Foster ââ */
. 
.     gen byte d1_educ  = 0
 23.     replace  d1_educ  = 1 if age >= 6 & (scol == 0 | missing(scol))
 24.     gen byte d2_sante = 0
 25.     replace  d2_sante = 1 if mal30j == 1 & con30j == 0 ///
>         & !missing(mal30j) & !missing(con30j)
 26.     gen byte d3_nutri = 0
 27.     replace  d3_nutri = 1 if age <= 4 & mal30j == 1 & !missing(mal30j)
 28.     gen byte d4_eau   = m_eau_source
 29.     gen byte d5_assai = m_toilet
 30.     gen byte d6_habit = dim_logem
 31. 
.     gen score_dep = (d1_educ + d2_sante + d3_nutri + ///
>                      d4_eau  + d5_assai + d6_habit) / 6
 32.     gen byte pauvre_AF = (score_dep >= $K_SEUIL) if !missing(score_dep)
 33. 
.     /* ââ Affichage ââ */
. 
.     di _newline "=== N-MODA `annee' (k=$K_MODA, 7 dimensions) ==="
 34.     quietly summarize pauvre_MODA
 35.     di "  H = " %6.3f r(mean)*100 "%"
 36.     di "  Privation par dimension :"
 37.     foreach dim in assai eau logem nutri sante protect educ {
 38.         taux_dep dim_`dim' "`dim'"
 39.     }
 40.     tabstat pauvre_MODA nb_dep, by(groupe_moda) stat(mean n) format(%6.3f)
 41. 
.     di _newline "=== Alkire-Foster `annee' (k=$K_SEUIL, 6 indicateurs) ==="
 42.     quietly summarize pauvre_AF
 43.     scalar H_af = r(mean)
 44.     quietly summarize score_dep if pauvre_AF == 1
 45.     scalar A_af = r(mean)
 46.     di "  H=" %6.3f H_af "  A=" %6.3f A_af "  M0=" %6.3f H_af * A_af
 47. end

. 
. /* ============================================================
>    Boucle principale sur les deux annees
>    ============================================================ */
. 
. foreach annee in 2018 2021 {
  2. 
.     if `annee' == 2018 local base "$BASE_2018"
  3.     else               local base "$BASE_2021"
  4. 
.     /* 1. Individus 0-17 ans */
.     use "`base'/ehcvm_individu_sen`annee'.dta", clear
  5.     keep if age >= 0 & age <= 17 & !missing(age)
  6.     gen annee = `annee'
  7.     di _newline ">>> Enfants `annee' : " _N
  8. 
.     /* 2. Welfare (hhsize, pcexp, covariables PSM) */
.     merge m:1 grappe menage using ///
>         "`base'/ehcvm_welfare_sen`annee'.dta", ///
>         keepusing(hhsize pcexp region milieu hgender hage heduc hmstat hhweight) ///
>         nogenerate keep(master match)
  9. 
.     /* 3. Indicateurs menage */
.     indic_menage `annee'
 10. 
.     /* 4. Acte de naissance */
.     indic_acte_nais `annee'
 11. 
.     /* 5. Indicateurs individuels */
. 
.     /* Non-scolarise (5-14 ans) */
.     gen byte m_scol = 0
 12.     replace  m_scol = 1 if age >= 5 & age <= 14 & (scol == 0 | missing(scol))
 13. 
.     /* Travail des enfants (5-14 ans) */
.     gen byte m_trav_enf = 0
 14.     replace  m_trav_enf = 1 if age >= 5 & age <= 14 & ///
>         (activ7j == 1 | activ7j == 2) & !missing(activ7j)
 15. 
.     /* Separation parentale */
.     gen byte m_parents = (lien > 3) if !missing(lien)
 16.     replace  m_parents = 0 if missing(m_parents)
 17. 
.     /* Illettrisme (15-17 ans) */
.     gen byte m_alfab = 0
 18.     if `annee' == 2018 {
 19.         replace m_alfab = 1 if age >= 15 & alfab == 0 & !missing(alfab)
 20.     }
 21.     else {
 22.         capture confirm variable alfa
 23.         if !_rc replace m_alfab = 1 if age >= 15 & alfa == 0 & !missing(alfa)
 24.     }
 25. 
.     /* NEET (15-17 ans) */
.     gen byte m_neet = 0
 26.     replace  m_neet = 1 if age >= 15 & ///
>         (scol == 0 | missing(scol)) & (activ7j == 0 | missing(activ7j))
 27. 
.     /* Acte de naissance non pertinent > 14 ans */
.     replace m_acte_nais = 0 if age > 14
 28. 
.     /* 6. Agregation IPM */
.     agreger_ipm `annee'
 29. 
.     /* 7. Sauvegarde */
