=== 1. Profil des mĂ©nages ===

. 
. foreach annee in 2018 2021 {
  2.     use "$TEMP/vague_`annee'.dta", clear
  3.     bysort grappe menage: keep if _n == 1   /* un mĂ©nage = une ligne */
  4. 
.     merge m:1 grappe menage using "$TEMP/traitement_`annee'.dta", ///
>         keepusing(D) nogenerate keep(master match)
  5.     replace D = 0 if missing(D)
  6. 
.     /* Taille mĂ©nage, Ă˘ge CM, milieu, transferts */
.     quietly {
  7.         gen byte chef_f = (hgender == 2)
  8.         gen byte urbain = (milieu == 1)
  9.         foreach v in hhsize hage pcexp chef_f urbain D {
 10.             summarize `v'
 11.             if "`v'" == "hhsize" scalar m_hhsize_`annee' = r(mean)
 12.             if "`v'" == "hage"   scalar m_hage_`annee'   = r(mean)
 13.             if "`v'" == "pcexp"  scalar m_pcexp_`annee'  = r(mean)
 14.             if "`v'" == "chef_f" scalar p_chef_f_`annee' = r(mean)*100
 15.             if "`v'" == "urbain" scalar p_urbain_`annee' = r(mean)*100
 16.             if "`v'" == "D"      scalar p_D_`annee'      = r(mean)*100
 17.         }
 18.         count
 19.         scalar n_men_`annee' = r(N)
 20.     }
 21.     di "`annee' : " n_men_`annee' " mĂ©nages"
 22.     di "  Taille moy : " %5.2f m_hhsize_`annee'
 23.     di "  PCE moy    : " %12.0f m_pcexp_`annee' " FCFA/an"
 24.     di "  Chef fĂ©minin  : " %5.1f p_chef_f_`annee' "%"
 25.     di "  Milieu urbain : " %5.1f p_urbain_`annee' "%"
 26.     di "  Transferts    : " %5.1f p_D_`annee'      "%"
 27. }
