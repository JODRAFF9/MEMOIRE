. do "code/stata/03_deprivation.do"

. /* ============================================================
>    03_deprivation.do ã Indicateurs de pauvrete multidimensionnelle
> 
>    Approche 1 : Alkire-Foster (M0 = H x A, k = 1/3, 6 indicateurs)
>    Approche 2 : N-MODA Senegal (ANSD/UNICEF 2024)
>                7 dimensions, k = 4, approche union intra-dimension
> 
>    Variables EHCVM (verifiees dans codebooks 2018 et 2021) :
>      ehcvm_individu : age, scol, mal30j, con30j, activ7j, lien
>                       alfab (2018) / alfa (2021)
>      ehcvm_menage   : eauboi_ss, eauboi_sp (0=non ameliore)
>                       toilet (0=non sain), ordure (0=non sain)
>      s11_me         : s11q02 (nb pieces)
>                       s11q29a/s11q28a (tps eau saison seche, min)
>                       s11q56/s11q55 (partage toilettes, 1=Oui)
>                       s11q53__1..7 (2018) / s11q52__1..7 (2021) (combustible)
>      s01_me         : s01q05 (acte naissance : 1=Oui 2=Non)
>                       s01q00a (2018) / membres__id (2021) = cle individuelle
>    ============================================================ */
. 
. 
. /* ============================================================
>    BOUCLE SUR LES DEUX ANNEES
>    ============================================================ */
. 
. foreach annee in 2018 2021 {
  2. 
.     if `annee' == 2018 local base "$BASE_2018"
  3.     else               local base "$BASE_2021"
  4. 
.     /* ----------------------------------------------------------
>        1. Individus 0-17 ans
>     ---------------------------------------------------------- */
. 
.     use "`base'/ehcvm_individu_sen`annee'.dta", clear
  5.     keep if age >= 0 & age <= 17 & !missing(age)
  6.     gen annee = `annee'
  7. 
.     /* Groupes d'age MODA */
.     gen byte groupe_moda = .
  8.     replace  groupe_moda = 1 if age <= 4
  9.     replace  groupe_moda = 2 if age >= 5  & age <= 14
 10.     replace  groupe_moda = 3 if age >= 15 & age <= 17
 11.     label define grp 1 "0-4 ans" 2 "5-14 ans" 3 "15-17 ans", replace
 12.     label values groupe_moda grp
 13. 
.     di _newline ">>> Enfants `annee' : " _N
 14. 
.     /* ----------------------------------------------------------
>        2. Indicateurs niveau menage ã Dimensions 1 a 5
>           Fusion ehcvm_menage (binaires harmonises)
>     ---------------------------------------------------------- */
. 
.     merge m:1 grappe menage using "`base'/ehcvm_menage_sen`annee'.dta", ///
>         keepusing(toilet eauboi_ss eauboi_sp ordure) ///
>         nogenerate keep(master match)
 15. 
.     /* Dim 1 ã ASSAINISSEMENT : toilet binaire (0=non sain) */
.     gen byte m_toilet = (toilet == 0) if !missing(toilet)
 16. 
.     /* Dim 2 ã EAU : eauboi_ss/sp binaires (0=non ameliore) */
.     gen byte m_eau_source = (eauboi_ss == 0 | eauboi_sp == 0) ///
>         if !missing(eauboi_ss) | !missing(eauboi_sp)
 17. 
.     /* Dim 3 ã LOGEMENT : ordure binaire (0=non sain) */
.     gen byte m_ordures = (ordure == 0) if !missing(ordure)
 18. 
.     /* ----------------------------------------------------------
>        3. Indicateurs niveau menage ã Fichier brut s11_me
>     ---------------------------------------------------------- */
. 
.     /* Noms de variables qui different entre 2018 et 2021 */
.     if `annee' == 2018 {
 19.         local v_partag  "s11q56"    /* partage toilettes (1=Oui) */
 20.         local v_tps_ss  "s11q29a"   /* temps eau saison seche (min) */
 21.         local v_comb    "s11q53"    /* prefixe combustible */
 22.     }
 23.     else {
 24.         local v_partag  "s11q55"
 25.         local v_tps_ss  "s11q28a"
 26.         local v_comb    "s11q52"
 27.     }
 28. 
.     /* Variables de combustible a recuperer */
.     local comb_vars "`v_comb'__1 `v_comb'__2 `v_comb'__3 `v_comb'__7"
 29. 
.     preserve
 30.         use "`base'/s11_me_sen`annee'.dta", clear
 31.         keep grappe menage s11q02 `v_partag' `v_tps_ss' `comb_vars'
 32.         tempfile s11_temp
 33.         save `s11_temp'
 34.     restore
 35. 
.     merge m:1 grappe menage using `s11_temp', nogenerate keep(master match)
 36. 
.     /* Dim 1 ã Partage toilettes */
.     gen byte m_partag_toi = (`v_partag' == 1) if !missing(`v_partag')
 37.     replace  m_partag_toi = 0 if missing(m_partag_toi)
 38. 
.     /* Dim 2 ã Temps acces eau > 30 min */
.     gen byte m_eau_temps = (`v_tps_ss' > 30 & !missing(`v_tps_ss'))
 39.     replace  m_eau_temps = 0 if missing(`v_tps_ss')
 40. 
.     /* Dim 3 ã Surpeuplement > 3 personnes par piece */
.     /* hhsize depuis welfare ã joint plus bas ; s11q02 = nb pieces */
.     gen byte m_surpeup = .   /* sera calcule apres merge welfare */
 41.     rename s11q02 nb_pieces
 42. 
.     /* Dim 5 ã Combustible solide (bois, charbon, dechets animaux) */
.     /* Codes 1/2/3 = 1er/2em/3em choix ; on prend >= 1 = mentionne */
.     gen byte m_combust = 0
 43.     foreach v of varlist `comb_vars' {
 44.         replace m_combust = 1 if `v' >= 1 & !missing(`v')
 45.     }
 46. 
.     /* ----------------------------------------------------------
>        4. Welfare : hhsize pour surpeuplement + pcexp
>     ---------------------------------------------------------- */
. 
.     merge m:1 grappe menage using ///
>         "`base'/ehcvm_welfare_sen`annee'.dta", ///
>         keepusing(hhsize pcexp region milieu ///
>                   hgender hage heduc hmstat) ///
>         nogenerate keep(master match)
 47. 
.     replace m_surpeup = (hhsize / nb_pieces > 3) ///
>         if !missing(nb_pieces) & nb_pieces > 0 & !missing(hhsize)
 48.     replace m_surpeup = 0 if missing(m_surpeup)
 49. 
.     /* ----------------------------------------------------------
>        5. Acte de naissance depuis s01_me
>           Cle individuelle : s01q00a (2018) / membres__id (2021)
>     ---------------------------------------------------------- */
. 
.     preserve
 50.         use "`base'/s01_me_sen`annee'.dta", clear
 51.         if `annee' == 2018 rename s01q00a numind
 52.         else               rename membres__id numind
 53.         keep grappe menage numind s01q05
 54.         gen byte m_acte_nais = (s01q05 == 2) if !missing(s01q05)
 55.         tempfile s01_temp
 56.         save `s01_temp'
 57.     restore
 58. 
.     merge m:1 grappe menage numind using `s01_temp', ///
>         keepusing(m_acte_nais) nogenerate keep(master match)
 59.     replace m_acte_nais = 0 if missing(m_acte_nais)
 60. 
.     /* ----------------------------------------------------------
>        6. Indicateurs individuels ã Dim 6 (Protection) et 7 (Education)
>     ---------------------------------------------------------- */
. 
.     /* Dim 6 ã Protection de l'enfant */
. 
.     /* Acte de naissance (0-14 ans) ã deja calcule */
.     replace m_acte_nais = 0 if age > 14
 61. 
.     /* Travail des enfants (5-14 ans) : activ7j = 1 (occupe) ou 2 (chomeur) */
.     gen byte m_trav_enf = 0
 62.     replace  m_trav_enf = 1 if age >= 5 & age <= 14 & ///
>         (activ7j == 1 | activ7j == 2) & !missing(activ7j)
 63. 
.     /* Separation parentale : lien > 3 => pas fils/fille du CM */
.     gen byte m_parents = (lien > 3) if !missing(lien)
 64.     replace  m_parents = 0 if missing(m_parents)
 65. 
.     /* Dim 7 ã Education */
. 
.     /* Non-scolarise (5-14 ans) */
.     gen byte m_scol = 0
 66.     replace  m_scol = 1 if age >= 5 & age <= 14 & ///
>         (scol == 0 | missing(scol))
 67. 
.     /* Illettrisme (15-17 ans) */
.     gen byte m_alfab = 0
 68.     if `annee' == 2018 {
 69.         replace m_alfab = 1 if age >= 15 & alfab == 0 & !missing(alfab)
 70.     }
 71.     else {
 72.         /* 2021 : variable nommee "alfa" */
.         capture confirm variable alfa
 73.         if !_rc replace m_alfab = 1 if age >= 15 & alfa == 0 & !missing(alfa)
 74.     }
 75. 
.     /* NEET (15-17 ans) : ni scolarise ni occupe */
.     gen byte m_neet = 0
 76.     replace  m_neet = 1 if age >= 15 & ///
>         (scol == 0 | missing(scol)) & ///
>         (activ7j == 0 | missing(activ7j))
 77. 
.     /* ----------------------------------------------------------
>        7. Agregation par dimension (approche union intra-dimension)
>     ---------------------------------------------------------- */
. 
.     /* Dim 4 NUTRITION : non disponible en variable harmonisee */
.     /* A calculer depuis s14_me et s20_me ã code a 0 provisoirement */
.     gen byte m_diversite = 0
 78.     gen byte m_securite  = 0
 79. 
.     /* Dim 5 SANTE : acces_sante non disponible (module communaute) */
.     gen byte m_acces_sante = 0
 80. 
.     /* Union intra-dimension */
.     gen byte dim_assai   = (m_toilet == 1 | m_partag_toi == 1)
 81.     gen byte dim_eau     = (m_eau_source == 1 | m_eau_temps == 1)
 82.     gen byte dim_logem   = (m_ordures == 1 | m_surpeup == 1)
 83.     gen byte dim_nutri   = (m_diversite == 1 | m_securite == 1)
 84.     gen byte dim_sante   = (m_combust == 1 | m_acces_sante == 1)
 85. 
.     /* Protection (varie selon groupe d'age) */
.     gen byte dim_protect = 0
 86.     replace  dim_protect = (m_acte_nais == 1 | m_parents == 1) ///
>         if groupe_moda == 1
 87.     replace  dim_protect = (m_acte_nais == 1 | m_trav_enf == 1 | m_parents == 1) ///
>         if groupe_moda == 2
 88.     replace  dim_protect = (m_parents == 1) if groupe_moda == 3
 89. 
.     /* Education (varie selon groupe d'age) */
.     gen byte dim_educ = 0
 90.     replace  dim_educ = m_scol if groupe_moda == 2
 91.     replace  dim_educ = (m_alfab == 1 | m_neet == 1) if groupe_moda == 3
 92. 
.     /* ----------------------------------------------------------
>        8. Indicateurs N-MODA (k = 4)
>     ---------------------------------------------------------- */
. 
.     gen byte nb_dep = dim_assai + dim_eau + dim_logem + dim_nutri + ///
>                       dim_sante + dim_protect + dim_educ
 93. 
.     gen byte pauvre_MODA = (nb_dep >= $K_MODA) if !missing(nb_dep)
 94. 
.     di _newline "=== N-MODA `annee' (k=4, 7 dimensions) ==="
 95.     di "[Note] dim_nutri = 0 (s14_me/s20_me non harmonises)"
 96.     quietly summarize pauvre_MODA
 97.     di "  H (incidence)  = " %6.3f r(mean)*100 "%"
 98.     quietly summarize nb_dep if pauvre_MODA == 1
 99.     di "  A (intensite)  = " %6.3f r(mean)/7
100. 
.     di "  Privation par dimension :"
101.     foreach dim in assai eau logem nutri sante protect educ {
102.         taux_dep dim_`dim' "`dim'"
103.     }
104. 
.     di _newline "  Prevalence par groupe d'age :"
105.     tabstat pauvre_MODA nb_dep, by(groupe_moda) stat(mean n) format(%6.3f)
106. 
.     /* ----------------------------------------------------------
>        9. Alkire-Foster (conserve pour comparaison)
>           6 indicateurs, poids egaux 1/6, k = 1/3
>     ---------------------------------------------------------- */
. 
.     gen byte d1_educ  = 0
107.     replace  d1_educ  = 1 if age >= 6 & (scol == 0 | missing(scol))
108. 
.     gen byte d2_sante = 0
109.     replace  d2_sante = 1 if mal30j == 1 & con30j == 0 & ///
>         !missing(mal30j) & !missing(con30j)
110. 
.     gen byte d3_nutri = 0
111.     replace  d3_nutri = 1 if age <= 4 & mal30j == 1 & !missing(mal30j)
112. 
.     gen byte d4_eau   = m_eau_source
113.     gen byte d5_assai = m_toilet
114.     gen byte d6_habit = dim_logem
115. 
.     gen score_dep = (d1_educ + d2_sante + d3_nutri + ///
>                      d4_eau  + d5_assai + d6_habit) / 6
116. 
.     gen byte pauvre_AF = (score_dep >= $K_SEUIL) if !missing(score_dep)
117. 
.     di _newline "=== Alkire-Foster `annee' (k=1/3, 6 indicateurs) ==="
118.     quietly summarize pauvre_AF
119.     scalar H_af = r(mean)
120.     quietly summarize score_dep if pauvre_AF == 1
121.     scalar A_af = r(mean)
122.     di "  H=" %6.3f H_af "  A=" %6.3f A_af "  M0=" %6.3f H_af * A_af
123. 
.     /* ----------------------------------------------------------
>        10. Sauvegarde
>     ---------------------------------------------------------- */
. 
.     save "$TEMP/enfants_dep_`annee'.dta", replace
124.     di _newline ">>> Sauvegarde : enfants_dep_`annee'.dta (" _N " obs)"
125. 
. } /* fin boucle annees */
