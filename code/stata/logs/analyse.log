. do "code/stata/01_visitation.do"

. /* ============================================================
>    01_visitation.do â Exploration des deux bases EHCVM
>    ============================================================ */
. 
. do "code/stata/config.do"

. /* ============================================================
>    config.do â Chemins, constantes et options globales
>    ============================================================ */
. 
. global BASE_2018 "Base/2018-2019/SEN_2018_EHCVM_v02_M_Stata"

. global BASE_2021 "Base/2021-2022/SEN_2021_EHCVM-2_v01_M_STATA14"

. global OUTPUT    "code/stata/output"

. global TEMP      "code/stata/temp"

. global LOGS      "code/stata/logs"

. 
. /* Parametres methodologiques */
. global SEED              123

. global K_SEUIL           0.3333   /* seuil Alkire-Foster (2 indicateurs sur 6) */

. global K_MODA            4        /* seuil N-MODA : >= 4 dimensions sur 7      */

. global N_BOOT            1000

. global CODE_ETRANGER_MIN 4        /* s13aq14 / s13q19 >= 4 = expediteur etranger */

. global CALIPER           0.05

. global K_VOISINS         4

. 
. set seed   $SEED

. set more   off

. set varabbrev off

. 
. foreach d in "$OUTPUT" "$TEMP" "$LOGS" {
  2.     capture mkdir "`d'"
  3. }

. 
end of do-file

. do "code/stata/utils.do"

. /* ============================================================
>    utils.do â Programmes utilitaires reutilisables
> 
>    Chaque programme est precede de "capture program drop" pour
>    eviter l'erreur r(110) "already defined" quand utils.do est
>    appele plusieurs fois dans la meme session Stata.
>    ============================================================ */
. 
. /* ââ Exploration rapide d'un fichier âââââââââââââââââââââââââ */
. capture program drop visiter

. program define visiter
  1.     args fichier nom
  2.     use "`fichier'", clear
  3.     di _newline "===== `nom' ====="
  4.     di "Observations : " _N
  5.     describe
  6.     codebook, compact
  7. end

. 
. /* ââ Taux de privation (%) ââââââââââââââââââââââââââââââââââââ */
. capture program drop taux_dep

. program define taux_dep
  1.     args var nom
  2.     quietly summarize `var'
  3.     di "  `nom' : " %5.1f r(mean)*100 "%"
  4. end

. 
. /* ââ Prevalence par statut de traitement ââââââââââââââââââââââ */
. capture program drop prev_D

. program define prev_D
  1.     args outcome
  2.     tabstat `outcome', by(D) stat(mean n) format(%6.3f)
  3. end

. 
. /* ââ ATT PSM-DD avec IC bootstrap ââââââââââââââââââââââââââââ */
. /*
>    Syntaxe : att_psmdd outcome poids nboot
>    Affiche ATT, SE bootstrap, IC 95%, p-valeur
> */
. capture program drop att_psmdd

. program define att_psmdd
  1.     args outcome poids nboot
  2. 
.     bootstrap att = _b[1.t#1.D], ///
>         reps(`nboot') seed($SEED) nodots: ///
>         reg `outcome' i.t##i.D [aw = `poids']
  3. 
.     estat bootstrap, percentile all
  4. end

. 
. /* ââ Verification equilibre SMD ââââââââââââââââââââââââââââââ */
. /*
>    Affiche les SMD avant/apres appariement pour une liste de vars
> */
. capture program drop check_balance

. program define check_balance
  1.     args varlist_str
  2.     di _newline "=== Balance des covariables (SMD) ==="
  3.     pstest `varlist_str', both
  4. end

. 
end of do-file

. 
. /* ââ EHCVM I (2018-2019) ââââââââââââââââââââââââââââââââââââ */
