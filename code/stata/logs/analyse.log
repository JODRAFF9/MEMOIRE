. 
. /* ============================================================
>    Sous-programme : indicateurs menage (niveau logement)
>    Entree : base individus deja chargee (merge m:1 sur grappe menage)
>    ============================================================ */
. 
. capture program drop indic_menage

. program define indic_menage
  1.     /*
>        Fusionne ehcvm_menage et s11_me pour construire :
>          m_toilet, m_eau_source, m_ordures,
>          m_partag_toi, m_eau_temps, m_surpeup, m_combust
>        Requiert : grappe menage hhsize deja presents
>     */
.     args annee
  2. 
.     if `annee' == 2018 {
  3.         local base "$BASE_2018"
  4.         local v_partag "s11q56"
  5.         local v_tps_ss "s11q29a"
  6.         local v_comb   "s11q53"
  7.     }
  8.     else {
  9.         local base "$BASE_2021"
 10.         local v_partag "s11q55"
 11.         local v_tps_ss "s11q28a"
 12.         local v_comb   "s11q52"
 13.     }
 14.     local comb_vars "`v_comb'__1 `v_comb'__2 `v_comb'__3 `v_comb'__7"
 15. 
.     /* Binaires harmonises depuis ehcvm_menage
>        NB : ehcvm_menage n'a pas grappe/menage, seulement hhid
>             2018 : hhid = grappe * 1000 + menage  (range 1001-598012)
>             2021 : hhid = grappe * 100  + menage  (range 201-59812)  */
.     capture drop hhid
 16.     if `annee' == 2018 gen long hhid = grappe * 1000 + menage
 17.     else               gen long hhid = grappe * 100  + menage
 18.     merge m:1 hhid using ///
>         "`base'/ehcvm_menage_sen`annee'.dta", ///
>         keepusing(toilet eauboi_ss eauboi_sp ordure) ///
>         nogenerate keep(master match)
 19. 
.     gen byte m_toilet    = (toilet == 0)          if !missing(toilet)
 20.     gen byte m_eau_source = (eauboi_ss == 0 | eauboi_sp == 0) ///
>         if !missing(eauboi_ss) | !missing(eauboi_sp)
 21.     gen byte m_ordures   = (ordure == 0)           if !missing(ordure)
 22. 
.     /* Variables brutes depuis s11_me */
.     preserve
 23.         use "`base'/s11_me_sen`annee'.dta", clear
 24.         keep grappe menage s11q02 `v_partag' `v_tps_ss' `comb_vars'
 25.         tempfile s11_temp
 26.         save `s11_temp'
 27.     restore
 28.     merge m:1 grappe menage using `s11_temp', nogenerate keep(master match)
 29. 
.     gen byte m_partag_toi = (`v_partag' == 1)       if !missing(`v_partag')
 30.     replace  m_partag_toi = 0                        if missing(m_partag_toi)
 31.     gen byte m_eau_temps  = (`v_tps_ss' > 30 & !missing(`v_tps_ss'))
 32.     replace  m_eau_temps  = 0                        if missing(`v_tps_ss')
 33.     rename s11q02 nb_pieces
 34. 
.     /* Surpeuplement : calcule apres merge welfare (hhsize deja present) */
.     gen byte m_surpeup = (hhsize / nb_pieces > 3) ///
>         if !missing(nb_pieces) & nb_pieces > 0 & !missing(hhsize)
 35.     replace  m_surpeup = 0 if missing(m_surpeup)
 36. 
.     /* Combustible solide */
.     gen byte m_combust = 0
 37.     foreach v of varlist `comb_vars' {
 38.         replace m_combust = 1 if `v' >= 1 & !missing(`v')
 39.     }
 40. 
.     /* â”€â”€ Dimension 4 : Nutrition (s08) â”€â”€ */
. 
.     /* Securite alimentaire FIES (s08a â€” 2018 et 2021)
>        Definition N-MODA : membre ayant saute un repas, mange moins que necessaire,
>        manque de nourriture, eu faim ou passe une journee sans manger
>        s08aq04 : saute repas | s08aq05 : mange moins | s08aq06 : plus de nourriture
>        s08aq07 : faim        | s08aq08 : journee sans manger
>        1=Oui 2=Non 98/99=NSP/Refus (traites comme Non)  */
.     preserve
 41.         use "`base'/s08a_me_sen`annee'.dta", clear
 42.         gen byte m_securite = 0
 43.         foreach v in s08aq04 s08aq05 s08aq06 s08aq07 s08aq08 {
 44.             replace m_securite = 1 if `v' == 1 & !missing(`v')
 45.         }
 46.         keep grappe menage m_securite
 47.         tempfile s08a_temp
 48.         save `s08a_temp'
 49.     restore
 50.     merge m:1 grappe menage using `s08a_temp', ///
>         keepusing(m_securite) nogenerate keep(master match)
 51.     replace m_securite = 0 if missing(m_securite)
 52. 
.     /* Diversite alimentaire (s08b1 â€” 2018 seulement)
>        Definition N-MODA : 4 macro-groupes (carbohydrates, proteines,
>        fruits/legumes, graisses) consommes chaque jour sur la semaine (7/7)
>        Mapping s08b02a-j :
>          Carbohydrates : max(a cereales, b tubercules)
>          Proteines     : max(c legumineuses, e poisson/viande, g lait/oeufs)
>          Fruits/legumes: max(d legumes, f fruits)
>          Graisses      : h huile/graisse
>        Prive si au moins un groupe < 7 jours (5-17 ans)  */
.     gen byte m_diversite = 0
 53.     if `annee' == 2018 {
 54.         preserve
 55.             use "`base'/s08b1_me_sen2018.dta", clear
 56.             foreach v of varlist s08b02a-s08b02j {
 57.                 replace `v' = 0 if missing(`v')
 58.             }
 59.             gen g_carb  = max(s08b02a, s08b02b)
 60.             gen g_prot  = max(s08b02c, s08b02e, s08b02g)
 61.             gen g_fv    = max(s08b02d, s08b02f)
 62.             gen g_gras  = s08b02h
 63.             gen byte m_diversite = ///
>                 (g_carb < 7 | g_prot < 7 | g_fv < 7 | g_gras < 7)
 64.             keep grappe menage m_diversite
 65.             tempfile s08b_temp
 66.             save `s08b_temp'
 67.         restore
 68.         merge m:1 grappe menage using `s08b_temp', ///
>             keepusing(m_diversite) nogenerate keep(master match)
 69.         replace m_diversite = 0 if missing(m_diversite)
 70.     }
 71. end

. 
. /* ============================================================
>    Sous-programme : acte de naissance (s01_me)
>    ============================================================ */
. 
. capture program drop indic_acte_nais

. program define indic_acte_nais
  1.     args annee
  2. 
.     if `annee' == 2018 local base "$BASE_2018"
  3.     else               local base "$BASE_2021"
  4. 
.     preserve
  5.         use "`base'/s01_me_sen`annee'.dta", clear
  6.         if `annee' == 2018 rename s01q00a numind
  7.         else               rename membres__id numind
  8.         keep grappe menage numind s01q05
  9.         gen byte m_acte_nais = (s01q05 == 2) if !missing(s01q05)
 10.         tempfile s01_temp
 11.         save `s01_temp'
 12.     restore
 13. 
.     merge m:1 grappe menage numind using `s01_temp', ///
>         keepusing(m_acte_nais) nogenerate keep(master match)
 14.     replace m_acte_nais = 0 if missing(m_acte_nais)
 15. end

. 
. /* ============================================================
>    Sous-programme : agregation N-MODA et Alkire-Foster
>    ============================================================ */
. 
. capture program drop agreger_ipm

. program define agreger_ipm
  1.     args annee
  2. 
.     /* Groupes d'age MODA */
.     gen byte groupe_moda = .
  3.     replace  groupe_moda = 1 if age <= 4
  4.     replace  groupe_moda = 2 if age >= 5  & age <= 14
  5.     replace  groupe_moda = 3 if age >= 15 & age <= 17
  6.     label define grp 1 "0-4 ans" 2 "5-14 ans" 3 "15-17 ans", replace
  7.     label values groupe_moda grp
  8. 
.     /* â”€â”€ Dimensions N-MODA (union intra-dimension) â”€â”€ */
. 
.     gen byte dim_assai  = (m_toilet == 1 | m_partag_toi == 1)
  9.     gen byte dim_eau    = (m_eau_source == 1 | m_eau_temps == 1)
 10.     gen byte dim_logem  = (m_ordures == 1 | m_surpeup == 1)
 11.     /* Nutrition : securite alim (0-17 ans) + diversite (5-17 ans) */
.     gen byte dim_nutri = 0
 12.     replace  dim_nutri = 1 if m_securite == 1
 13.     replace  dim_nutri = 1 if m_diversite == 1 & age >= 5
 14.     gen byte dim_sante  = (m_combust == 1)
 15.     gen byte dim_educ   = 0
 16.     replace  dim_educ   = m_scol  if groupe_moda == 2
 17.     replace  dim_educ   = (m_alfab == 1 | m_neet == 1) if groupe_moda == 3
 18.     gen byte dim_protect = 0
 19.     replace  dim_protect = (m_acte_nais == 1 | m_parents == 1) ///
>         if groupe_moda == 1
 20.     replace  dim_protect = (m_acte_nais == 1 | m_trav_enf == 1 | m_parents == 1) ///
>         if groupe_moda == 2
 21.     replace  dim_protect = (m_parents == 1) if groupe_moda == 3
 22. 
.     gen byte nb_dep    = dim_assai + dim_eau + dim_logem + dim_nutri + ///
>                          dim_sante + dim_protect + dim_educ
 23.     gen byte pauvre_MODA = (nb_dep >= $K_MODA) if !missing(nb_dep)
 24. 
.     /* â”€â”€ Indicateurs Alkire-Foster â”€â”€ */
. 
.     gen byte d1_educ  = 0
 25.     replace  d1_educ  = 1 if age >= 6 & (scol == 0 | missing(scol))
 26.     gen byte d2_sante = 0
 27.     replace  d2_sante = 1 if mal30j == 1 & con30j == 0 ///
>         & !missing(mal30j) & !missing(con30j)
 28.     gen byte d3_nutri = 0
 29.     replace  d3_nutri = 1 if age <= 4 & mal30j == 1 & !missing(mal30j)
 30.     gen byte d4_eau   = m_eau_source
 31.     gen byte d5_assai = m_toilet
 32.     gen byte d6_habit = dim_logem
 33. 
.     gen score_dep = (d1_educ + d2_sante + d3_nutri + ///
>                      d4_eau  + d5_assai + d6_habit) / 6
 34.     gen byte pauvre_AF = (score_dep >= $K_SEUIL) if !missing(score_dep)
 35. 
.     /* â”€â”€ Affichage â”€â”€ */
. 
.     di _newline "=== N-MODA `annee' (k=$K_MODA, 7 dimensions) ==="
 36.     quietly summarize pauvre_MODA
 37.     di "  H = " %6.3f r(mean)*100 "%"
 38.     di "  Privation par dimension :"
 39.     foreach dim in assai eau logem nutri sante protect educ {
 40.         taux_dep dim_`dim' "`dim'"
 41.     }
 42.     tabstat pauvre_MODA nb_dep, by(groupe_moda) stat(mean n) format(%6.3f)
 43. 
.     di _newline "=== Alkire-Foster `annee' (k=$K_SEUIL, 6 indicateurs) ==="
 44.     quietly summarize pauvre_AF
 45.     scalar H_af = r(mean)
 46.     quietly summarize score_dep if pauvre_AF == 1
 47.     scalar A_af = r(mean)
 48.     di "  H=" %6.3f H_af "  A=" %6.3f A_af "  M0=" %6.3f H_af * A_af
 49. end

. 
. /* ============================================================
>    Boucle principale sur les deux annees
>    ============================================================ */
. 
. foreach annee in 2018 2021 {
  2. 
.     if `annee' == 2018 local base "$BASE_2018"
  3.     else               local base "$BASE_2021"
  4. 
.     /* 1. Individus 0-17 ans */
.     use "`base'/ehcvm_individu_sen`annee'.dta", clear
  5.     keep if age >= 0 & age <= 17 & !missing(age)
  6.     gen annee = `annee'
  7.     di _newline ">>> Enfants `annee' : " _N
  8. 
.     /* 2. Welfare (hhsize, pcexp, covariables PSM) */
.     merge m:1 grappe menage using ///
>         "`base'/ehcvm_welfare_sen`annee'.dta", ///
>         keepusing(hhsize pcexp region milieu hgender hage heduc hmstat hhweight) ///
>         nogenerate keep(master match)
  9. 
.     /* 3. Indicateurs menage */
.     indic_menage `annee'
 10. 
.     /* 4. Acte de naissance */
.     indic_acte_nais `annee'
 11. 
.     /* 5. Indicateurs individuels */
. 
.     /* Non-scolarise (5-14 ans) */
.     gen byte m_scol = 0
 12.     replace  m_scol = 1 if age >= 5 & age <= 14 & (scol == 0 | missing(scol))
 13. 
.     /* Travail des enfants (5-14 ans) */
.     gen byte m_trav_enf = 0
 14.     replace  m_trav_enf = 1 if age >= 5 & age <= 14 & ///
>         (activ7j == 1 | activ7j == 2) & !missing(activ7j)
 15. 
.     /* Separation parentale */
.     gen byte m_parents = (lien > 3) if !missing(lien)
 16.     replace  m_parents = 0 if missing(m_parents)
 17. 
.     /* Illettrisme (15-17 ans) */
.     gen byte m_alfab = 0
 18.     if `annee' == 2018 {
 19.         replace m_alfab = 1 if age >= 15 & alfab == 0 & !missing(alfab)
 20.     }
 21.     else {
 22.         capture confirm variable alfa
 23.         if !_rc replace m_alfab = 1 if age >= 15 & alfa == 0 & !missing(alfa)
 24.     }
 25. 
.     /* NEET (15-17 ans) : ni scolarise ni employe (activ7j != 1 : inactifs + chomeurs) */
.     gen byte m_neet = 0
 26.     replace  m_neet = 1 if age >= 15 & ///
>         (scol == 0 | missing(scol)) & (activ7j != 1 | missing(activ7j))
 27. 
.     /* Acte de naissance non pertinent > 14 ans */
.     replace m_acte_nais = 0 if age > 14
 28. 
.     /* 6. Agregation IPM */
.     agreger_ipm `annee'
 29. 
.     /* 7. Sauvegarde */
.     save "$TEMP/enfants_dep_`annee'.dta", replace
 30.     di _newline ">>> Sauvegarde : enfants_dep_`annee'.dta (" _N " obs)"
 31. }
