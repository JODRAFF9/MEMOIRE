. do "code/stata/02_traitement.do"

. /* ============================================================
>    02_traitement.do â Variable de traitement + identifiant panel
> 
>    D = 1 si le menage a recu un transfert de l'etranger
>    panel_id = identifiant unique grappe-menage pour le panel vrai
> 
>    NB : s13aq14 (2018) et s13q19 (2021) indiquent le pays de
>         l'expediteur ; >= CODE_ETRANGER_MIN => transfert etranger
>    ============================================================ */
. 
. do "code/stata/config.do"

. /* ============================================================
>    config.do â Chemins, constantes et options globales
>    ============================================================ */
. 
. global BASE_2018 "Base/2018-2019/SEN_2018_EHCVM_v02_M_Stata"

. global BASE_2021 "Base/2021-2022/SEN_2021_EHCVM-2_v01_M_STATA14"

. global OUTPUT    "code/stata/output"

. global TEMP      "code/stata/temp"

. global LOGS      "code/stata/logs"

. 
. /* Parametres methodologiques */
. global SEED              123

. global K_SEUIL           0.3333   /* seuil Alkire-Foster (2 indicateurs sur 6) */

. global K_MODA            4        /* seuil N-MODA : >= 4 dimensions sur 7      */

. global N_BOOT            1000

. global CODE_ETRANGER_MIN 4        /* s13aq14 / s13q19 >= 4 = expediteur etranger */

. global CALIPER           0.05

. global K_VOISINS         4

. 
. set seed   $SEED

. set more   off

. set varabbrev off

. 
. foreach d in "$OUTPUT" "$TEMP" "$LOGS" {
  2.     capture mkdir "`d'"
  3. }

. 
end of do-file

. do "code/stata/utils.do"

. /* ============================================================
>    utils.do â Programmes utilitaires reutilisables
> 
>    Chaque programme est precede de "capture program drop" pour
>    eviter l'erreur r(110) "already defined" quand utils.do est
>    appele plusieurs fois dans la meme session Stata.
>    ============================================================ */
. 
. /* ââ Exploration rapide d'un fichier âââââââââââââââââââââââââ */
. capture program drop visiter

. program define visiter
  1.     args fichier nom
  2.     use "`fichier'", clear
  3.     di _newline "===== `nom' ====="
  4.     di "Observations : " _N
  5.     describe
  6.     codebook, compact
  7. end

. 
. /* ââ Taux de privation (%) ââââââââââââââââââââââââââââââââââââ */
. capture program drop taux_dep

. program define taux_dep
  1.     args var nom
  2.     quietly summarize `var'
  3.     di "  `nom' : " %5.1f r(mean)*100 "%"
  4. end

. 
. /* ââ Prevalence par statut de traitement ââââââââââââââââââââââ */
. capture program drop prev_D

. program define prev_D
  1.     args outcome
  2.     tabstat `outcome', by(D) stat(mean n) format(%6.3f)
  3. end

. 
. /* ââ ATT PSM-DD avec IC bootstrap ââââââââââââââââââââââââââââ */
. /*
>    Syntaxe : att_psmdd outcome poids nboot
>    Affiche ATT, SE bootstrap, IC 95%, p-valeur
> */
. capture program drop att_psmdd

. program define att_psmdd
  1.     args outcome poids nboot
  2. 
.     bootstrap att = _b[1.t#1.D], ///
>         reps(`nboot') seed($SEED) nodots: ///
>         reg `outcome' i.t##i.D [aw = `poids']
  3. 
.     estat bootstrap, percentile all
  4. end

. 
. /* ââ Verification equilibre SMD ââââââââââââââââââââââââââââââ */
. /*
>    Affiche les SMD avant/apres appariement pour une liste de vars
> */
. capture program drop check_balance

. program define check_balance
  1.     args varlist_str
  2.     di _newline "=== Balance des covariables (SMD) ==="
  3.     pstest `varlist_str', both
  4. end

. 
end of do-file

. 
. /* ââ Sous-programme : construire D pour une annee âââââââââââ */
. 
. capture program drop construire_traitement

. program define construire_traitement
  1.     /*
>        args : annee  var_lieu  fichier_detail  fichier_liste
>               annee      = 2018 ou 2021
>               var_lieu   = nom de la variable lieu expediteur
>               fichier_detail = s13a_2 (2018) ou s13_2 (2021)
>               fichier_liste  = s13a_1 (2018) ou s13_1 (2021)
>     */
.     args annee var_lieu fich_det fich_list
  2. 
.     /* Resoudre le chemin de base selon l'annee (evite l'ambiguite $BASE_`annee') */
.     if `annee' == 2018 local base "$BASE_2018"
  3.     else               local base "$BASE_2021"
  4. 
.     /* Identifier les menages avec au moins un transfert etranger */
.     use "`base'/`fich_det'_me_sen`annee'.dta", clear
  5.     keep if `var_lieu' >= $CODE_ETRANGER_MIN & !missing(`var_lieu')
  6.     bysort grappe menage: keep if _n == 1
  7.     gen transfert_migrant = 1
  8.     keep grappe menage transfert_migrant
  9.     tempfile etrangers
 10.     save `etrangers'
 11. 
.     /* Fusionner sur la liste exhaustive des menages */
.     use "`base'/`fich_list'_me_sen`annee'.dta", clear
 12.     merge m:1 grappe menage using `etrangers', ///
>         keepusing(transfert_migrant) nogenerate
 13.     replace transfert_migrant = 0 if missing(transfert_migrant)
 14.     rename transfert_migrant D
 15.     bysort grappe menage: keep if _n == 1
 16.     label var D "Traitement : transfert de migrant recu (1=oui)"
 17.     keep grappe menage D
 18.     save "$TEMP/traitement_`annee'.dta", replace
 19. 
.     quietly summarize D
 20.     di "  `annee' : " %5.1f r(mean)*100 "%  (" %4.0f r(sum) "/" %5.0f r(N) " menages)"
 21. end

. 
. /* ââ Construction pour chaque vague ââââââââââââââââââââââââ */
. 
